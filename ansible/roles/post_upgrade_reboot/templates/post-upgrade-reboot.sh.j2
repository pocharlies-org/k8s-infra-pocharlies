#!/usr/bin/env bash
# {{ ansible_managed }}
# Reboots this control-plane in its daily window when apt left
# /var/run/reboot-required, without ever taking down etcd quorum.
#
# Why this exists: on 2026-06-10 unattended-upgrades updated the systemd
# package; the postinst daemon-reexec corrupted PID 1 (journald/resolved dead,
# -.mount failed) and every later service stop became permanent, killing k3s
# and tailscaled and locking the node out (SSH is tailscale-only). A prompt
# scheduled reboot after such upgrades prevents days of running on a
# half-reexeced systemd.
#
# 2026-06-11 (OVH CS15972406): rebooting WITHOUT draining made the shutdown
# hang ~6min on Longhorn iSCSI writes (dirty ext4 on CNPG/RabbitMQ volumes,
# ~2h of faulted-volume recovery, Harbor down -> cluster-wide
# ImagePullBackOff) and the >10min ping gap dispatched an OVH datacenter tech
# who power-cycled the node mid-boot. Hence: cordon+drain BEFORE rebooting
# (clean volume detach, fast shutdown, ping gap below OVH's ~10min
# intervention threshold); post-upgrade-uncordon.service restores
# schedulability after boot.
#
# Decision matrix:
#   no reboot-required flag            -> exit 0
#   node already cordoned (no marker)  -> skip (operator intent, do not fight)
#   local k3s healthy + peers Ready    -> drain, reboot (cluster covers us)
#   drain fails or times out           -> uncordon, skip (retry next window)
#   local k3s healthy + a peer NotReady-> skip (do not shrink quorum further)
#   local k3s broken                   -> reboot regardless, no drain possible
#                                         (we contribute nothing; reboot is
#                                         the cure — peers checked over TCP
#                                         only for the log)
set -uo pipefail

SELF="{{ inventory_hostname }}"
PEERS=({% for host, ip in post_upgrade_reboot_peer_ips.items() if host != inventory_hostname %}"{{ host }}:{{ ip }}" {% endfor %})
FLAG="${REBOOT_REQUIRED_FLAG:-/var/run/reboot-required}"
DRAIN_TIMEOUT="{{ post_upgrade_reboot_drain_timeout_seconds }}"
MARKER_DIR=/var/lib/post-upgrade-reboot
MARKER="$MARKER_DIR/cordoned"
DRY_RUN=0
[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=1

log() { logger -t post-upgrade-reboot -- "$*"; echo "post-upgrade-reboot: $*"; }

if [[ ! -f "$FLAG" ]]; then
  if [[ "$DRY_RUN" == "1" ]]; then
    log "dry-run: no $FLAG, continuing checks anyway"
  else
    log "no $FLAG; nothing to do"
    exit 0
  fi
else
  log "reboot required: $(tr '\n' ' ' <"$FLAG")"
  [[ -f "${FLAG}.pkgs" ]] && log "packages: $(sort -u "${FLAG}.pkgs" | tr '\n' ' ')"
fi

do_reboot() {
  if [[ "$DRY_RUN" == "1" ]]; then
    log "dry-run: WOULD REBOOT now ($*)"
    exit 0
  fi
  log "rebooting: $*"
  wall "post-upgrade-reboot: rebooting $SELF now ($*)" 2>/dev/null || true
  sync
  systemctl reboot &
  # PID 1 may be too corrupted to act on the request (the very failure mode
  # this script exists for) — force the syscall after a grace period.
  sleep 90
  log "systemctl reboot did not act after 90s; forcing reboot -f"
  sync
  reboot -f
}

# --- local k3s health -------------------------------------------------------
KUBECTL_OK=0
NODES_OUT=""
if NODES_OUT=$(timeout 20 k3s kubectl get nodes --no-headers 2>/dev/null); then
  KUBECTL_OK=1
fi

if [[ "$KUBECTL_OK" == "0" ]]; then
  # Local k3s broken: log peer reachability (TCP etcd peer port) and reboot.
  for peer in "${PEERS[@]}"; do
    ip="${peer##*:}"
    if timeout 4 bash -c "echo > /dev/tcp/${ip}/2380" 2>/dev/null; then
      log "peer ${peer%%:*} etcd port reachable"
    else
      log "WARNING: peer ${peer%%:*} etcd port UNREACHABLE"
    fi
  done
  # Best-effort etcd snapshot is pointless here (k3s is down); just go.
  do_reboot "local k3s broken, reboot is the cure"
fi

# --- local k3s healthy: only reboot if every peer control-plane is Ready ----
for peer in "${PEERS[@]}"; do
  name="${peer%%:*}"
  status=$(awk -v n="$name" '$1==n {print $2}' <<<"$NODES_OUT")
  if [[ "$status" != "Ready" ]]; then
    log "SKIP: peer $name status='${status:-absent}' (not Ready); refusing to shrink quorum"
    exit 0
  fi
done
log "all peer control-planes Ready"

# --- already cordoned and not by us? operator intent — leave the node alone -
UNSCHED=$(timeout 20 k3s kubectl get node "$SELF" -o jsonpath='{.spec.unschedulable}' 2>/dev/null)
if [[ "$UNSCHED" == "true" && ! -f "$MARKER" ]]; then
  log "SKIP: $SELF is cordoned by an operator; not rebooting"
  exit 0
fi

# --- drain: detach Longhorn volumes cleanly so shutdown stays fast ----------
if [[ "$DRY_RUN" == "1" ]]; then
  log "dry-run: would cordon+drain $SELF (timeout ${DRAIN_TIMEOUT}s) before reboot"
else
  if ! timeout 30 k3s kubectl cordon "$SELF" >/dev/null 2>&1; then
    log "WARNING: cordon failed; skipping reboot this window"
    exit 0
  fi
  mkdir -p "$MARKER_DIR"
  touch "$MARKER"
  log "draining $SELF (timeout ${DRAIN_TIMEOUT}s)"
  # --force covers unmanaged pods (reboot would kill them anyway); PDBs
  # (CNPG primary switchover, RabbitMQ quorum, Longhorn last-replica) are
  # respected by the eviction API and are exactly why a failed drain must
  # abort the reboot instead of proceeding.
  if timeout $((DRAIN_TIMEOUT + 60)) k3s kubectl drain "$SELF" \
       --ignore-daemonsets --delete-emptydir-data --force \
       --timeout="${DRAIN_TIMEOUT}s" 2>&1 | logger -t post-upgrade-reboot; then
    log "drain complete"
  else
    log "WARNING: drain failed/timed out; uncordoning and skipping this window"
    if timeout 30 k3s kubectl uncordon "$SELF" >/dev/null 2>&1; then
      rm -f "$MARKER"
    else
      log "WARNING: uncordon also failed; marker kept, post-upgrade-uncordon will retry on next boot"
    fi
    exit 0
  fi
fi

# Fresh local etcd snapshot before going down (best effort, cron ones are 6h).
if [[ "$DRY_RUN" == "0" ]]; then
  if timeout 90 k3s etcd-snapshot save --name "pre-reboot-auto" >/dev/null 2>&1; then
    log "local etcd snapshot pre-reboot-auto saved"
  else
    log "WARNING: pre-reboot etcd snapshot failed; continuing (6h cron snapshots exist)"
  fi
fi

do_reboot "post-upgrade window, cluster healthy"
