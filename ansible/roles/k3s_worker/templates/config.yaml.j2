server: "{{ k3s_worker_join_server_effective }}"
token: "{{ lookup('env', 'K3S_TOKEN') }}"
node-ip: {{ ansible_host }}
flannel-iface: {{ k3s_flannel_iface }}
kubelet-arg:
  - max-pods=200
node-label:
  - node-pool=home-dev
  - node-role=dev-fast
  - storage=local-fast
  - topology=home
  - workload=dev
