{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListOnlyTheOpenClawBackupPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:ListBucketMultipartUploads"
      ],
      "Resource": [
        "arn:aws:s3:::longhorn-backups"
      ],
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "openclaw",
            "openclaw/*"
          ]
        }
      }
    },
    {
      "Sid": "ManageOnlyOpenClawBackupObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": [
        "arn:aws:s3:::longhorn-backups/openclaw/*"
      ]
    }
  ]
}
